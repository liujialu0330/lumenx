{
  "name": "lumenx",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/dev-setup.js",
    "dev": "concurrently --kill-others-on-fail -n backend,frontend,open -c blue,green,cyan \"npm run dev:backend\" \"npm run dev:frontend\" \"node scripts/open-browser.js\"",
    "dev:backend": "cross-env NO_PROXY=*.aliyuncs.com,localhost,127.0.0.1 no_proxy=*.aliyuncs.com,localhost,127.0.0.1 .venv/Scripts/python -m uvicorn src.apps.comic_gen.api:app --reload --port 17177 --host 0.0.0.0",
    "dev:frontend": "cd frontend && npm run dev"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3"
  }
}
